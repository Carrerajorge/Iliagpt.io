  "scripts": {
    "dev:client": "vite dev --port 5000",
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "tsx script/build.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:agentic": "vitest run tests/agentic",
    "test:all": "bash ./scripts/test-all.sh",
    "test:smoke": "npx playwright test e2e/smoke.spec.ts --reporter=list",
    "lint": "eslint .",
    "daemon": "node --import tsx server/daemon/desktopDaemon.ts",
    "dev:desktop": "concurrently \"npm run dev\" \"npm run dev:client\" \"wait-on http://localhost:5050 && electron .\"",
    "build:desktop:mac": "npm run build && tsc -p desktop/tsconfig.json && npx electron-builder --mac",
    "build:desktop:win": "npm run build && tsc -p desktop/tsconfig.json && npx electron-builder --win",
    "build:extension": "mkdir -p dist/extension && cp -r extension/* dist/extension/ && cd dist/extension && zip -r ../../client/public/downloads/ILIAGPT-Chrome-Extension-v1.5.0.zip *",
    "worker": "node --import tsx server/worker.ts",
    "postinstall": "node scripts/sync-mathjax-assets.cjs",
    "sync:mathjax": "node scripts/sync-mathjax-assets.cjs",
    "type-check": "node scripts/with-env.cjs NODE_OPTIONS=--max-old-space-size=8192 -- tsc -p tsconfig.ci.json",
    "type-check:app": "node scripts/with-env.cjs NODE_OPTIONS=--max-old-space-size=8192 -- tsc -p tsconfig.ci.json",
    "prepare": "husky",
    "db:ensure-extensions": "node --import tsx scripts/db/ensure-extensions.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:bootstrap": "npm run db:ensure-extensions && npm run db:migrate",
    "db:migrate:prod": "node dist/migrate.cjs",
    "test:coverage:istanbul": "vitest run --pool=forks --coverage --maxWorkers=1 --no-file-parallelism --coverage.reportsDirectory=coverage --coverage.provider=istanbul --coverage.reporter=text --coverage.reporter=json --coverage.reporter=json-summary --coverage.reporter=html",
    "test:agentic:integration": "bash ./scripts/test-agentic-integration.sh",
    "test:client": "vitest run --config vitest.client.config.ts",
    "test:client:watch": "vitest --config vitest.client.config.ts",
    "test:client:coverage": "vitest run --config vitest.client.config.ts --coverage",
    "test:i18n": "vitest run --config vitest.client.config.ts client/src/lib/i18n.test.ts client/src/lib/i18n.dom.test.tsx client/src/lib/i18n.100-locales.test.ts",
    "i18n:check": "node --import tsx scripts/i18n/check-coverage.ts",
    "verify:i18n": "npm run i18n:check && npm run test:i18n",
    "verify": "bash ./scripts/agent-verify.sh",
    "verify:sandbox": "AGENT_VERIFY_SKIP_TESTS=true bash ./scripts/agent-verify.sh",
    "test:e2e": "npx playwright test --reporter=html",
    "test:emaiti": "node scripts/run-emaiti-capabilities.cjs",
    "generate:openclaw1000": "node scripts/generate-openclaw1000.cjs /Users/ale/Downloads/Iliagpt_1000_Implementaciones_Limpio.txt /Users/ale/Desktop/ILIACODEX/Hola",
    "test:openclaw1000": "vitest run tests/unit/openclaw1000-service.test.ts tests/unit/openclaw1000-capability-profiler.test.ts",
    "tool-runner:capabilities": "node --import tsx server/toolRunner/cli.ts --capabilities",
    "tool-runner:health": "node --import tsx server/toolRunner/cli.ts --healthcheck",
    "tool-runner:test": "npm run test:run -- server/toolRunner/cli.contract.test.ts server/toolRunner/orchestrator.golden.test.ts",
    "quality:gate": "node --import tsx scripts/quality-gate.ts",
    "verify:prod": "bash ./scripts/prod-rigorous-checks.sh",
    "test:prod:agentic100": "node --import tsx scripts/prod-agentic-rigorous-100.ts",
    "test:e2e:prod:rigorous": "npx playwright test e2e/production-rigorous.spec.ts --config=playwright.prod.config.ts",
    "build:desktop:linux": "npm run build && tsc -p desktop/tsconfig.json && npx electron-builder --linux",
    "build:desktop:all": "npm run build && tsc -p desktop/tsconfig.json && npx electron-builder --mac --win --linux"
  },
