modules = ["postgresql-16", "nodejs-22"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["jq", "unzip", "zlib"]

[deployment]
deploymentTarget = "autoscale"
build = ["bash", "script/deploy-build.sh"]
run = ["node", "dist/index.cjs"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8001
externalPort = 3000

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_OPTIONS='--max-old-space-size=1536' npm run dev"
waitForPort = 5000

[agent]
mockupState = "FULLSTACK"
integrations = ["javascript_xai:1.0.0", "javascript_object_storage:2.0.0", "javascript_replit_auth:2.0.0", "javascript_gemini:1.0.0", "stripe:2.0.0", "resend:1.0.0", "google-mail:1.0.0", "javascript_anthropic:1.0.0"]

[userenv]

[userenv.shared]
ROUTER_CONFIDENCE_THRESHOLD = "0.65"
MAX_AGENT_STEPS = "8"
ENABLE_DYNAMIC_ESCALATION = "true"
AGENTIC_PIPELINE_ENABLED = "true"
OPENAI_BASE_URL = "https://openrouter.ai/api/v1"
AGENTIC_CHAT_ENABLED = "true"
ALLOWED_HOSTS = "iliagpt.io,www.iliagpt.io"

[userenv.development]
START_PYTHON_SERVICE = "true"
PYTHON_TOOLS_PORT = "8001"

[userenv.production]
BASE_URL = "https://iliagpt.io"

[objectStorage]
defaultBucketID = "replit-objstore-8cdb9c3b-9e44-4c99-9aed-500e8b41061c"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
