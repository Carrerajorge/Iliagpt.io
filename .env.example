# ============================================================
# IliaGPT.io — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# Add ".env" to your .gitignore if it is not already there.
#
# All variables are validated at startup via Zod (server/config/env.ts).
# The server will refuse to start if required variables are missing or invalid.
# ============================================================


# ------------------------------------------------------------
# Core — Required for all deployments
# ------------------------------------------------------------

# Application environment. One of: development | test | production
NODE_ENV=development

# Port the Express server listens on.
PORT=5000

# Primary PostgreSQL connection string.
# Must have pgvector extension available.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/iliagpt

# Optional PostgreSQL read replica. When set, SELECT queries are routed here.
# Leave blank to disable read replica routing.
DATABASE_READ_URL=

# Redis connection string. Required in production for SSE fan-out, rate limiting,
# and response caching. Optional in development (falls back to in-process state).
# Format: redis://HOST:PORT  or  redis://:PASSWORD@HOST:PORT  or  rediss://HOST:PORT (TLS)
REDIS_URL=redis://localhost:6379

# Session secret — minimum 64 random characters.
# Generate with: openssl rand -hex 64
SESSION_SECRET=


# ------------------------------------------------------------
# LLM Providers — At least one key is required to start
# ------------------------------------------------------------
# The smart router selects providers based on task complexity, cost, and availability.
# Configure multiple providers for fallback resilience.

# OpenAI — GPT-4o, o3, o4-mini, text-embedding-3-small
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — Claude 3.5, Claude 3.7, Claude 4 series
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini — Gemini 2.0 Flash, Gemini 1.5 Pro
# https://aistudio.google.com — click "Get API key"
GEMINI_API_KEY=
# Alternative variable name (both are accepted)
# GOOGLE_AI_STUDIO_KEY=

# xAI — Grok-2, Grok-3
# https://console.x.ai
XAI_API_KEY=

# DeepSeek — DeepSeek-V3, DeepSeek-R1
# https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Cerebras — Llama 3.3 70B (extremely fast inference)
# https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Mistral AI — Mistral Large, Mixtral 8x22B
# https://console.mistral.ai
MISTRAL_API_KEY=

# Cohere — Command R+
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Groq — Llama 3 (fastest open-weight inference)
# https://console.groq.com/keys
GROQ_API_KEY=

# Together AI — broad open-weight model catalog
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# OpenRouter — unified endpoint for 200+ models from many providers
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Fireworks AI — fine-tuned and open-weight models
# https://fireworks.ai/api-keys
FIREWORKS_API_KEY=

# Perplexity — online models with real-time web retrieval built in
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Azure OpenAI — enterprise OpenAI with data residency guarantees
# https://portal.azure.com — create an Azure OpenAI resource
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Ollama — local model inference, no cloud dependency
# Run: ollama serve  (default port 11434)
# Pull a model: ollama pull llama3.3
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio — local models via OpenAI-compatible API
# Start the LM Studio local server from the app (default port 1234)
LMSTUDIO_BASE_URL=http://localhost:1234


# ------------------------------------------------------------
# Authentication — Configure at least one OAuth provider
# ------------------------------------------------------------

# Google OAuth 2.0
# https://console.cloud.google.com — Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: https://your-domain.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Azure AD OAuth 2.0
# https://portal.azure.com — App registrations → New registration
# Authorized redirect URI: https://your-domain.com/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Auth0 (universal SSO broker — supports SAML, OIDC, social providers)
# https://manage.auth0.com — Applications → Regular Web Application
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# HMAC secret for anonymous session tokens (Safari ITP workaround).
# Used to sign X-Anonymous-Token headers. Generate: openssl rand -hex 32
ANONYMOUS_USER_HMAC_SECRET=


# ------------------------------------------------------------
# External Integrations & MCP Connectors
# ------------------------------------------------------------
# Set the relevant variables to enable each connector.
# Connectors without their required variables are silently disabled at startup.

# Telegram Bot
# https://t.me/BotFather — /newbot command
TELEGRAM_BOT_TOKEN=

# Slack Bot (OAuth app with bot token scope)
# https://api.slack.com/apps — Create New App → Bot Token Scopes
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=

# GitHub App (for issue/PR creation and repo access)
# https://github.com/settings/apps — New GitHub App
GITHUB_APP_ID=
# Paste the full PEM private key (newlines as \n) or set the path to the .pem file
GITHUB_APP_PRIVATE_KEY=

# Notion Integration
# https://www.notion.so/my-integrations — New Integration
NOTION_API_KEY=

# Linear (project management)
# https://linear.app/settings/api — Personal API Keys
LINEAR_API_KEY=

# Jira (Atlassian Cloud)
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=


# ------------------------------------------------------------
# File Storage
# ------------------------------------------------------------

# Local directory for uploaded files. Must be writable by the Node process.
UPLOAD_DIR=./uploads

# Maximum allowed upload size in megabytes.
MAX_FILE_SIZE_MB=100

# S3-Compatible Object Storage (optional — replaces local disk storage)
# Works with AWS S3, Google Cloud Storage (S3-interop), MinIO, Backblaze B2, etc.
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Custom endpoint for non-AWS providers (e.g., MinIO). Leave blank for AWS S3.
S3_ENDPOINT=


# ------------------------------------------------------------
# Feature Flags — Enable or disable major capabilities
# ------------------------------------------------------------

# Allow agents to control a browser (OpenClaw subsystem).
# Requires the OpenClaw WebSocket gateway to be running.
ENABLE_BROWSER_AUTOMATION=true

# Allow agents to write and execute code in the Python sandbox.
# Requires the FastAPI microservice (fastapi_sse/) to be running.
ENABLE_CODE_EXECUTION=true

# Extract and recall facts across conversations.
# Requires pgvector extension in PostgreSQL.
ENABLE_LONG_TERM_MEMORY=true

# Allow users and admins to create cron-scheduled and webhook-triggered agent tasks.
ENABLE_SCHEDULED_TASKS=true

# Enable MCP connector catalog (Slack, Notion, GitHub, Jira, Linear, etc.).
ENABLE_MCP_CONNECTORS=true

# Allow unauthenticated users to interact via anonymous sessions.
# Uses ANONYMOUS_USER_HMAC_SECRET for token signing.
ENABLE_ANONYMOUS_ACCESS=true

# Send anonymous usage telemetry to the IliaGPT team to help improve the product.
# No chat content or personal data is included. Set to true to opt in.
ENABLE_TELEMETRY=false


# ------------------------------------------------------------
# Observability — Logging, Metrics, and Tracing
# ------------------------------------------------------------

# OpenTelemetry collector endpoint (OTLP/HTTP).
# Leave blank to disable trace export. Works with Jaeger, Grafana Tempo, Honeycomb, etc.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Service name reported in traces and logs.
OTEL_SERVICE_NAME=iliagpt

# Log verbosity level. One of: error | warn | info | debug | trace
# Use "debug" for local development, "info" or "warn" in production.
LOG_LEVEL=info

# Expose a /metrics endpoint in Prometheus text format.
# Requires prometheus client library to be installed.
PROMETHEUS_METRICS_ENABLED=false


# ------------------------------------------------------------
# Stripe Payments — Subscription & Credits
# ------------------------------------------------------------
# Required for checkout, subscription management, and credits purchases.
# Create a Stripe account at https://dashboard.stripe.com
# Use test mode keys (sk_test_*, pk_test_*) for development.

# Stripe publishable key (frontend). Starts with pk_test_ or pk_live_.
STRIPE_PUBLISHABLE_KEY=

# Stripe secret key (server only). Starts with sk_test_ or sk_live_.
STRIPE_SECRET_KEY=

# Stripe webhook endpoint secret. Starts with whsec_.
# Create at: https://dashboard.stripe.com/webhooks → Add endpoint
# Endpoint URL: https://your-domain.com/api/stripe/webhook
# Events to listen: checkout.session.completed, customer.subscription.*,
#   invoice.payment_succeeded, invoice.payment_failed, charge.refunded, charge.dispute.*
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for each subscription tier.
# Create products & prices at: https://dashboard.stripe.com/products
# Or run: ALLOW_STRIPE_PRODUCT_SEEDING=true then POST /api/stripe/create-products
STRIPE_PRICE_GO=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Enable the /api/stripe/create-products endpoint to seed Stripe products.
# Only set to true during initial setup, then disable.
ALLOW_STRIPE_PRODUCT_SEEDING=false

# Admin email for purchase notifications.
ADMIN_EMAIL=


# ------------------------------------------------------------
# Budget & Rate Limiting
# ------------------------------------------------------------
# Budget enforcement prevents runaway LLM spend per user per day.
# All amounts are in USD. Budgets reset at midnight UTC.

# Daily LLM spend cap for free-tier users.
FREE_DAILY_BUDGET_USD=0.50

# Daily LLM spend cap for Pro-tier users.
PRO_DAILY_BUDGET_USD=5.00

# Daily LLM spend cap for Enterprise-tier users.
ENTERPRISE_DAILY_BUDGET_USD=50.00

# Rate limiting window duration in milliseconds (default: 60 seconds).
RATE_LIMIT_WINDOW_MS=60000

# Maximum number of API requests per user per window.
RATE_LIMIT_MAX_REQUESTS=100


# ------------------------------------------------------------
# Code Execution Sandbox (FastAPI Python Microservice)
# ------------------------------------------------------------
# The Python microservice (fastapi_sse/) runs agent-generated code in a
# restricted environment. Start it with: cd fastapi_sse && uvicorn main:app

# Base URL of the FastAPI sandbox microservice.
FASTAPI_SSE_URL=http://localhost:8000

# Maximum wall-clock time for a single code execution in milliseconds.
SANDBOX_TIMEOUT_MS=30000

# Maximum memory the sandbox process may use in megabytes.
SANDBOX_MEMORY_MB=512


# ------------------------------------------------------------
# Application — URLs, Cookies, and Proxy
# ------------------------------------------------------------

# Public-facing base URL of the application (no trailing slash).
# Used for OAuth redirect URIs, email links, and CORS origin validation.
APP_URL=http://localhost:5000

# Cookie domain. Use your root domain in production (e.g., .iliagpt.io)
# to share session cookies across subdomains.
COOKIE_DOMAIN=localhost

# Set to true when the app is behind a reverse proxy (nginx, Caddy, Traefik, AWS ALB).
# Tells Express to trust X-Forwarded-For and X-Forwarded-Proto headers.
TRUST_PROXY=false

# Optional: override the CORS allowed origins (comma-separated).
# Defaults to APP_URL. Useful when the API is served from a different origin than the frontend.
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
