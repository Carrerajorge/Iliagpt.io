# =============================================================================
# IliaGPT — Kubernetes Secret Template (EXAMPLE — DO NOT COMMIT REAL VALUES)
# Usage: copy to secret.yaml, fill real values (base64-encoded), apply
#        kubectl apply -f k8s/secret.yaml
#
# Encode a value:  echo -n 'my-value' | base64
# Decode a value:  echo 'bXktdmFsdWU=' | base64 -d
#
# In production, use an external secrets manager:
#   - AWS Secrets Manager + External Secrets Operator
#   - HashiCorp Vault + Vault Agent Injector
#   - GCP Secret Manager + External Secrets Operator
#   - Azure Key Vault + CSI driver
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: iliagpt-secrets
  namespace: iliagpt
  labels:
    app.kubernetes.io/name: iliagpt
    app.kubernetes.io/component: secrets
  annotations:
    # If using external-secrets-operator, add sync annotation here
    # external-secrets.io/sync-policy: Automatic
type: Opaque
data:
  # ── Database ─────────────────────────────────────────────────────────────────
  # echo -n 'postgres://user:pass@host:5432/dbname' | base64
  DATABASE_URL: cG9zdGdyZXM6Ly91c2VyOnBhc3NAaG9zdDo1NDMyL2RibmFtZQ==

  # echo -n 'postgres://user:pass@read-replica:5432/dbname' | base64
  DATABASE_READ_URL: cG9zdGdyZXM6Ly91c2VyOnBhc3NAcmVhZC1yZXBsaWNhOjU0MzIvZGJuYW1l

  # ── Redis ────────────────────────────────────────────────────────────────────
  # echo -n 'redis://:password@redis-host:6379' | base64
  REDIS_URL: cmVkaXM6Ly86cGFzc3dvcmRAcmVkaXMtaG9zdDo2Mzc5

  # ── Sessions ─────────────────────────────────────────────────────────────────
  # echo -n 'at-least-32-random-chars' | base64
  SESSION_SECRET: YXQtbGVhc3QtMzItcmFuZG9tLWNoYXJz

  # ── LLM Provider API Keys ────────────────────────────────────────────────────
  OPENAI_API_KEY: c2stcHJvai14eHh4eHh4eA==
  ANTHROPIC_API_KEY: c2stYW50LXh4eHh4eHh4
  GOOGLE_AI_API_KEY: QUl6YVN5eHh4eHh4
  XAI_API_KEY: eGFpLXh4eHh4eHh4
  DEEPSEEK_API_KEY: c2steHh4eHh4eHh4
  OPENROUTER_API_KEY: b3Itemhlci14eHh4eHh4
  CEREBRAS_API_KEY: Y2ViLXh4eHh4eHh4

  # ── OAuth ────────────────────────────────────────────────────────────────────
  GOOGLE_CLIENT_ID: eHh4eHh4LmFwcHMuZ29vZ2xldXNlcmNvbnRlbnQuY29t
  GOOGLE_CLIENT_SECRET: R09DU1AteHh4eHh4eHh4
  MICROSOFT_CLIENT_ID: eHh4eHh4LW1pY3Jvc29mdA==
  MICROSOFT_CLIENT_SECRET: eHh4eHh4LW1pY3Jvc29mdC1zZWNyZXQ=

  # ── Telegram / WhatsApp ───────────────────────────────────────────────────────
  TELEGRAM_BOT_TOKEN: eHh4eHh4OnRlbGVncmFtLXRva2Vu
  WHATSAPP_API_KEY: eHh4eHh4LXdoYXRzYXBw

  # ── Encryption ───────────────────────────────────────────────────────────────
  # 32-byte hex key for AES-256
  ENCRYPTION_KEY: eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eA==

  # ── Storage (S3-compatible) ───────────────────────────────────────────────────
  S3_ACCESS_KEY_ID: QUtJQXh4eHh4eHh4
  S3_SECRET_ACCESS_KEY: eHh4eHh4eHh4eHh4eHh4eA==
