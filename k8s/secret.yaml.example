apiVersion: v1
kind: Secret
metadata:
  name: iliagpt-secrets
  namespace: iliagpt
  labels:
    app: iliagpt
    app.kubernetes.io/component: secrets
# IMPORTANT: Copy this file to secret.yaml, fill in real values (base64-encoded),
# and NEVER commit secret.yaml to version control.
# Encode:  echo -n "my-value" | base64
# Decode:  echo "bXktdmFsdWU=" | base64 -d
type: Opaque
data:
  # ── Database ─────────────────────────────────────────────────────────────────
  # echo -n "strong-random-password" | base64
  POSTGRES_PASSWORD: ""
  DATABASE_URL: ""           # postgresql://iliagpt:<pw>@postgres-service:5432/iliagpt
  DATABASE_READ_URL: ""      # optional read replica

  # ── Redis ─────────────────────────────────────────────────────────────────────
  REDIS_PASSWORD: ""
  REDIS_URL: ""              # redis://:<pw>@redis-service:6379

  # ── Session ───────────────────────────────────────────────────────────────────
  # openssl rand -base64 64 | base64
  SESSION_SECRET: ""

  # ── LLM API keys ─────────────────────────────────────────────────────────────
  ANTHROPIC_API_KEY: ""
  OPENAI_API_KEY: ""
  GEMINI_API_KEY: ""
  XAI_API_KEY: ""
  MISTRAL_API_KEY: ""
  OPENROUTER_API_KEY: ""
  CEREBRAS_API_KEY: ""
  DEEPSEEK_API_KEY: ""

  # ── OAuth ─────────────────────────────────────────────────────────────────────
  GOOGLE_CLIENT_ID: ""
  GOOGLE_CLIENT_SECRET: ""
  MICROSOFT_CLIENT_ID: ""
  MICROSOFT_CLIENT_SECRET: ""
  AUTH0_CLIENT_ID: ""
  AUTH0_CLIENT_SECRET: ""
  AUTH0_DOMAIN: ""

  # ── CSRF / HMAC ───────────────────────────────────────────────────────────────
  CSRF_SECRET: ""
  ANONYMOUS_TOKEN_SECRET: ""

  # ── Storage (S3-compatible) ───────────────────────────────────────────────────
  S3_ACCESS_KEY_ID: ""
  S3_SECRET_ACCESS_KEY: ""
  S3_BUCKET: ""
  S3_REGION: ""
  S3_ENDPOINT: ""

  # ── Notifications / integrations ─────────────────────────────────────────────
  TELEGRAM_BOT_TOKEN: ""
  SLACK_BOT_TOKEN: ""
  SENDGRID_API_KEY: ""

  # ── Monitoring ───────────────────────────────────────────────────────────────
  SENTRY_DSN: ""
  GRAFANA_API_KEY: ""
