      "title": "Active Pods",
      "type": "stat",
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"iliagpt\",deployment=\"iliagpt\"}",
          "legendFormat": "pods",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
