          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"iliagpt-app\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
