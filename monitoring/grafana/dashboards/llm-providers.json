{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "description": "IliaGPT LLM Provider Performance — latency, errors, tokens, cost, circuit breakers",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Provider Health Overview",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "text": "Closed" }, "1": { "color": "red", "text": "Open" }, "2": { "color": "yellow", "text": "Half-Open" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "Circuit Breaker State by Provider",
      "type": "stat",
      "targets": [
        { "expr": "llm_circuit_breaker_state", "legendFormat": "{{ provider }}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 200,
      "title": "Request Volume & Error Rates",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 10,
      "title": "LLM Request Rate by Provider",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (provider) (rate(llm_requests_total[5m]))",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "percentunit" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 11,
      "title": "LLM Error Rate by Provider",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (provider) (rate(llm_requests_total{status=\"error\"}[5m])) / sum by (provider) (rate(llm_requests_total[5m]))",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 300,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 20,
      "title": "LLM p50 Latency by Provider",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (provider, le) (rate(llm_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ provider }} p50",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "id": 21,
      "title": "LLM p95 Latency by Provider",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(llm_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ provider }} p95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 22,
      "title": "LLM p99 Latency by Provider",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (provider, le) (rate(llm_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ provider }} p99",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 400,
      "title": "Token Usage & Cost",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "id": 30,
      "title": "Input Tokens/s by Provider",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (provider) (rate(llm_input_tokens_total[5m]))",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "id": 31,
      "title": "Output Tokens/s by Provider",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (provider) (rate(llm_output_tokens_total[5m]))",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "currencyUSD" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "id": 32,
      "title": "Cost Rate by Provider (USD/hr)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (provider) (rate(llm_cost_usd_total[5m])) * 3600",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 500,
      "title": "Budget Enforcement",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 34 },
      "id": 40,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "Free Tier Budget Used Today",
      "type": "gauge",
      "targets": [
        {
          "expr": "llm_daily_cost_usd{tier=\"free\"} / 0.50",
          "legendFormat": "free tier",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 34 },
      "id": 41,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "Pro Tier Budget Used Today",
      "type": "gauge",
      "targets": [
        {
          "expr": "llm_daily_cost_usd{tier=\"pro\"} / 5.00",
          "legendFormat": "pro tier",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 34 },
      "id": 42,
      "title": "Smart Router — Model Selection",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (model, complexity) (rate(smart_router_selections_total[5m]))",
          "legendFormat": "{{ model }} ({{ complexity }})",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 600,
      "title": "Fallback & Retry Behaviour",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 50,
      "title": "Fallback Triggers by Provider",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (from_provider, to_provider) (rate(llm_fallback_total[5m]))",
          "legendFormat": "{{ from_provider }} → {{ to_provider }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 51,
      "title": "Circuit Breaker Trips",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (provider) (rate(llm_circuit_breaker_trips_total[5m]))",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["iliagpt", "llm", "providers"],
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "title": "IliaGPT — LLM Providers",
  "uid": "iliagpt-llm-providers",
  "version": 1
}
